# ==============================================================================
# SMELL-RANKER ENVIRONMENT CONFIGURATION (example.env)
# Copy this file to '.env' before running the pipeline.
# ==============================================================================

# --- Custom Workspace Path (Optional) ---
# If left blank, defaults to '[REPO_ROOT]/workspace_data'
SMELL_RANKER_HOME=

# ==============================================================================
# TOOLCHAIN CONFIGURATION
# Instructions for users:
# 1. Version: Use your preferred version of the tools.
# 2. URL: Provide the direct download URL for the tool archive.
#         *Ensure you verify the URL's legitimacy before use.*
# 3. SHA-256: Generate your own SHA-256 checksum for the downloaded file
#             to ensure local integrity and prevent tampering.
# ==============================================================================

# --- RefactoringMiner ---
RM_VERSION="RefactoringMiner-3.x.x"
RM_URL="https://github.com/tsantalis/RefactoringMiner/releases/download/.../RefactoringMiner-3.x.x.zip"
RM_SHA256="<generate_and_insert_your_sha256_checksum_here>"

# --- PMD ---
PMD_VERSION="pmd-bin-7.x.x"
PMD_URL="https://github.com/pmd/pmd/releases/download/.../pmd-dist-7.x.x-bin.zip"
PMD_SHA256="<generate_and_insert_your_sha256_checksum_here>"

# --- Pipeline I/O Resilience Configuration ---
IO_MAX_RETRIES=5
IO_RETRY_DELAY_BASE=0.1